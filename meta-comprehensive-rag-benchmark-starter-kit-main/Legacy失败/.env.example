DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
TASK1_DEBUG_PATH=

# 百炼 Qwen3-VL 视觉候选增强（默认关闭，API 异常时自动回退旧逻辑）
VISION_ENABLED=1
VISION_RERANK_ENABLED=1
VISION_RERANK_MODE=pure_visual
VISION_ANCHOR_FALLBACK_CONFIDENCE=0.70
ANSWER_RELIABILITY_ENABLED=0
VISUAL_VERIFIER_ENABLED=0
EVIDENCE_RETRY_ENABLED=0
EVIDENCE_RETRY_ENTITY_CONFIDENCE=0.70
QWEN_VL_PROVIDER=dashscope
QWEN_VL_ANCHOR_MODEL=qwen3.5-omni-plus
QWEN_VL_RERANK_MODEL=qwen3.5-omni-plus
QWEN_VL_FALLBACK_MODEL=qwen3-vl-flash
# 兼容旧配置：只设置 QWEN_VL_MODEL 时，anchor/rerank 都使用该值。
QWEN_VL_MODEL=
QWEN_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_API_KEY=
DASHSCOPE_API_KEY=
QWEN_VL_TIMEOUT=90
QWEN_VL_MAX_RETRIES=2
QWEN_VL_MAX_TOKENS=1024
QWEN_VL_RERANK_MAX_TOKENS=4096
QWEN_VL_ENABLE_THINKING=0
QWEN_VL_MAX_IMAGE_EDGE=1280
QWEN_VL_JPEG_QUALITY=92
VISION_RETRIEVAL_TOP_K=25
VISION_RERANK_TOP_N=10
VISION_MIN_CONFIDENCE=0.35
VISION_ANCHOR_CACHE=1
VISION_DEBUG_PATH=
