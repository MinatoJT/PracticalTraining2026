<Window
    x:Class="CRAGMM.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CRAG-MM Task Runner">

    <Grid Padding="18" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="CRAG-MM Task Runner" FontSize="26" FontWeight="SemiBold" />

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="14">
            <Grid RowSpacing="10" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Mode" VerticalAlignment="Center" />
                <ComboBox x:Name="ModeCombo" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Dataset evaluation" Tag="eval" IsSelected="True" />
                    <ComboBoxItem Content="Custom Task1 question" Tag="custom" />
                </ComboBox>

                <TextBlock Grid.Row="1" Text="Task" VerticalAlignment="Center" />
                <ComboBox x:Name="TaskCombo" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Task 1 - Single-source augmentation" Tag="task1" IsSelected="True" />
                    <ComboBoxItem Content="Task 2 - Multi-source augmentation" Tag="task2" />
                    <ComboBoxItem Content="Task 3 - Multi-turn QA" Tag="task3" />
                </ComboBox>

                <TextBlock Grid.Row="2" Text="Agent" VerticalAlignment="Center" />
                <ComboBox x:Name="AgentCombo" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Task1KGAgent" Tag="task1kg" IsSelected="True" />
                    <ComboBoxItem Content="Task2Agent" Tag="task2agent" />
                    <ComboBoxItem Content="Task3Agent" Tag="task3agent" />
                    <ComboBoxItem Content="user_config.UserAgent" Tag="user_config" />
                </ComboBox>

                <TextBlock Grid.Row="3" Text="Samples" VerticalAlignment="Center" />
                <NumberBox x:Name="ConversationCount" Grid.Row="3" Grid.Column="1" Minimum="1" Maximum="5000" Value="20" SpinButtonPlacementMode="Inline" />

                <TextBlock Grid.Row="4" Text="Display examples" VerticalAlignment="Center" />
                <NumberBox x:Name="DisplayCount" Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="50" Value="5" SpinButtonPlacementMode="Inline" />

                <TextBlock Grid.Row="5" Text="Eval model" VerticalAlignment="Center" />
                <ComboBox x:Name="EvalModelCombo" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="None - exact match" Tag="None" IsSelected="True" />
                    <ComboBoxItem Content="deepseek-v4-flash - semantic judge" Tag="deepseek-v4-flash" />
                    <ComboBoxItem Content="gpt-4o-mini - semantic judge" Tag="gpt-4o-mini" />
                </ComboBox>

                <TextBlock Grid.Row="6" Text="Custom image" VerticalAlignment="Center" />
                <Grid Grid.Row="6" Grid.Column="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ImagePathBox" PlaceholderText="Choose an image for a custom Task1 question" />
                    <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse" />
                </Grid>

                <TextBlock Grid.Row="7" Text="Question" VerticalAlignment="Center" />
                <TextBox x:Name="QuestionBox" Grid.Row="7" Grid.Column="1" PlaceholderText="Example: What is this building called?" />

                <TextBlock Grid.Row="8" Text="DeepSeek API Key" VerticalAlignment="Center" />
                <PasswordBox x:Name="ApiKeyBox" Grid.Row="8" Grid.Column="1" PlaceholderText="Optional for Task1/Task2 generation" />

                <TextBlock Grid.Row="9" Text="DeepSeek model" VerticalAlignment="Center" />
                <TextBox x:Name="DeepSeekModelBox" Grid.Row="9" Grid.Column="1" Text="deepseek-v4-flash" />

                <TextBlock Grid.Row="10" Text="Qwen VL vision" VerticalAlignment="Center" />
                <CheckBox x:Name="VisionEnabledBox" Grid.Row="10" Grid.Column="1" Content="Enable Qwen3-VL visual enhancement" />

                <TextBlock Grid.Row="11" Text="Qwen VL API Key" VerticalAlignment="Center" />
                <PasswordBox x:Name="QwenApiKeyBox" Grid.Row="11" Grid.Column="1" PlaceholderText="DashScope key; never shown in command preview" />

                <TextBlock Grid.Row="12" Text="Visual anchor model" VerticalAlignment="Center" />
                <TextBox x:Name="QwenAnchorModelBox" Grid.Row="12" Grid.Column="1" Text="qwen3.5-omni-plus" />

                <TextBlock Grid.Row="13" Text="Candidate rerank model" VerticalAlignment="Center" />
                <TextBox x:Name="QwenRerankModelBox" Grid.Row="13" Grid.Column="1" Text="qwen3.5-omni-flash" />

                <TextBlock Grid.Row="14" Text="Qwen VL Base URL" VerticalAlignment="Center" />
                <TextBox x:Name="QwenBaseUrlBox" Grid.Row="14" Grid.Column="1" Text="https://dashscope.aliyuncs.com/compatible-mode/v1" />

                <TextBlock Grid.Row="15" Text="Dataset revision" VerticalAlignment="Center" />
                <StackPanel Grid.Row="15" Grid.Column="1" Orientation="Horizontal" Spacing="14">
                    <TextBox x:Name="RevisionBox" Text="v0.1.2" Width="220" />
                    <CheckBox x:Name="DisableProgressBox" Content="Disable progress bars" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="RunButton" Content="Run" Width="96" />
                <Button x:Name="StopButton" Content="Stop" Width="96" IsEnabled="False" />
            </StackPanel>
            <TextBlock Grid.Row="1" Text="Command preview" />
            <TextBox x:Name="CommandPreviewBox" Grid.Row="2" IsReadOnly="True" TextWrapping="Wrap" MinHeight="72" />
        </Grid>

        <Grid Grid.Row="3" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="Output" />
            <TextBox x:Name="OutputBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" />
        </Grid>
    </Grid>
</Window>
